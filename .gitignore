# Secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/
# Exception: session-bundle lifecycle logs ARE structural state (audit trail of
# migrate_v1/pause/resume/end events) and must travel with the bundle for
# cross-machine portability per TASK-004 design.
!state/sessions/**/lifecycle.log

# Language runtimes (added defensively; uncomment as stacks land)
node_modules/
__pycache__/
*.pyc
.venv/
venv/
# NOTE (TASK-023): dist/ is NOT ignored — it holds the COMMITTED esbuild plugin
# bundles (dist/*.cjs) that are the plugin's shipped entrypoints. A git-URL
# plugin install ships no node_modules, so the self-contained bundles must
# travel in the repo. Regenerate them with `npm run build:plugin`.
build/

# Local-only Claude Code settings overrides (per-machine)
.claude/settings.local.json
