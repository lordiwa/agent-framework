{
  "$id": "https://agentic-framework.local/knowledge/schema.json",
  "title": "KnowledgeEntryFrontmatter",
  "description": "Machine-checkable schema for the YAML frontmatter of a knowledge/entries/<id>.md file. See schema.md for the human-readable version.",
  "type": "object",
  "required": ["id", "problem", "symptoms", "solution", "tags", "projects", "created_at", "last_seen_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$",
      "description": "Stable kebab-case slug; must match filename minus .md."
    },
    "problem": { "type": "string", "minLength": 10, "maxLength": 1000 },
    "symptoms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "solution": { "type": "string", "minLength": 10 },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "last_seen_at": { "type": "string", "format": "date-time" },
    "source_urls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" }
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "superseded_by": { "type": ["string", "null"] }
  }
}
